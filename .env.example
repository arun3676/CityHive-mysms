# ─────────────────────────────────────────────────────────────
# MySMS Messenger — environment template (SAFE TO COMMIT)
# Copy this to `.env` and fill in real values. `.env` is gitignored.
# ─────────────────────────────────────────────────────────────

# --- Twilio (SMS provider) ---
# Identifies WHICH Twilio account a request belongs to. Always required.
TWILIO_ACCOUNT_SID=

# Master password for the account. Simple but powerful — can do anything.
# Optional if you authenticate with an API Key instead (recommended).
TWILIO_AUTH_TOKEN=

# Scoped, revocable credential created just for this app (best practice).
# Used together with TWILIO_ACCOUNT_SID to authenticate.
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=

# The "from" number SMS is sent on. Must be E.164 format (+1...).
TWILIO_PHONE_NUMBER=

# Where Twilio POSTs delivery status (Bonus 3).
# Locally: an ngrok URL. In prod: the live Render URL.
TWILIO_STATUS_CALLBACK_URL=

# --- MongoDB (database) ---
# Full Atlas connection string the Rails app/Mongoid connects with.
MONGODB_URI=
