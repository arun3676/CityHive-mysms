# Backend environment variables (SAFE TO COMMIT — no real values here).
# Locally: copy to `backend/.env` and fill in. In production: set these in the
# Render dashboard. `.env` is gitignored.

# --- MongoDB (Atlas connection string) ---
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/mysms?retryWrites=true&w=majority

# --- Twilio (the app authenticates with Account SID + Auth Token) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sender number in E.164 format, e.g. +15551234567
TWILIO_PHONE_NUMBER=
# Bonus 3: Twilio POSTs delivery status here. In production use your Render URL:
#   https://<your-api>.onrender.com/api/messages/status_callback
TWILIO_STATUS_CALLBACK_URL=

# --- App ---
# Comma-separated frontend origin(s) allowed by CORS in production,
# e.g. https://your-app.vercel.app
FRONTEND_ORIGIN=http://localhost:4200

# Signs the session cookie in production. Generate with:  bundle exec rails secret
# (On Render this is auto-generated by render.yaml.)
SECRET_KEY_BASE=
